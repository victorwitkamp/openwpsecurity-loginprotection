{
	"name": "victorwitkamp/openwpsecurity-loginprotection",
	"description": "WordPress login-event tracking, temporary bans, failed-password analysis, and permanent bans.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"funding": [
		{
			"type": "github",
			"url": "https://github.com/sponsors/victorwitkamp"
		}
	],
	"autoload": {
		"psr-4": {
			"VictorWitkamp\\OpenWPSecurity\\LoginProtection\\": "src/"
		}
	},
	"require": {
		"laminas/laminas-diactoros": "^3.8",
		"laminas/laminas-httphandlerrunner": "^2.13",
		"openwpsecurity/core": "^0.5.0",
		"php-di/php-di": "^7.0",
		"php": ">=8.2"
	},
	"require-dev": {
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"squizlabs/php_codesniffer": "^3.13",
		"szepeviktor/phpstan-wordpress": "^2.0",
		"wp-coding-standards/wpcs": "^3.0"
	},
	"scripts": {
		"install-codestandards": [
			"PHPCSStandards\\Composer\\Plugin\\Installers\\PHPCodeSniffer\\Plugin::run"
		],
		"phpcs": [
			"phpcs --standard=phpcs.xml.dist"
		],
		"phpcbf": [
			"phpcbf --standard=phpcs.xml.dist"
		],
		"strict-types": [
			"phpcs --standard=phpcs.xml.dist --sniffs=Generic.PHP.RequireStrictTypes openwpsecurity-loginprotection.php src templates uninstall.php languages phpstan-bootstrap.php"
		],
		"phpstan": [
			"phpstan analyse --configuration=phpstan.neon.dist --no-progress --memory-limit=1G"
		],
		"lint": [
			"@phpcs",
			"@strict-types"
		],
		"analyse": [
			"@phpstan"
		],
		"check": [
			"@lint",
			"@analyse"
		]
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		},
		"autoloader-suffix": "OpenWPSecurityLoginProtectionAutoloader",
		"sort-packages": true
	}
}
