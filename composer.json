{
	"name": "victorwitkamp/openwpsecurity-loginprotection",
	"description": "Development tooling for the OpenWPSecurity - Login Protection plugin.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"repositories": [
		{
			"type": "path",
			"url": "../openwpsecurity-core",
			"options": {
				"symlink": true,
				"versions": {
					"openwpsecurity/core": "0.1.0"
				}
			}
		}
	],
	"autoload": {
		"psr-4": {
			"VictorWitkamp\\OpenWPSecurity\\LoginProtection\\": "src/"
		}
	},
	"require": {
		"laminas/laminas-diactoros": "^3.8",
		"laminas/laminas-httphandlerrunner": "^2.13",
		"openwpsecurity/core": "^0.1",
		"php-di/php-di": "^7.0"
	},
	"require-dev": {
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"squizlabs/php_codesniffer": "^3.13",
		"wp-coding-standards/wpcs": "^3.0"
	},
	"scripts": {
		"install-codestandards": [
			"PHPCSStandards\\Composer\\Plugin\\Installers\\PHPCodeSniffer\\Plugin::run"
		],
		"phpcs": [
			"phpcs --standard=phpcs.xml.dist"
		],
		"phpcbf": [
			"phpcbf --standard=phpcs.xml.dist"
		]
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		},
		"autoloader-suffix": "OpenWPSecurityLoginProtectionAutoloader",
		"sort-packages": true
	}
}
